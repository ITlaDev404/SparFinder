# =====================================================
# FICHIER D'ENVIRONNEMENT - BACKEND
# =====================================================
#
# Variables de configuration pour la connexion
# à la base de données MariaDB.
#
# Ces valeurs sont chargées par dotenv dans index.ts

# Hôte de la base de données (localhost)
DB_HOST=127.0.0.1

# Port MariaDB (défaut MySQL/MariaDB)
DB_PORT=3306

# Utilisateur de la base de données
DB_USER=root

# Mot de passe de l'utilisateur
DB_PASSWORD=root

# Nom de la base de données
DB_NAME=sparfinder

# =====================================================
# JWT CONFIGURATION
# =====================================================
# Secret pour signer les tokens JWT (doit être long et complexe)
JWT_SECRET=pigeonAIR_super_secret_key_2026_change_in_production

# Durée d'expiration des tokens JWT (30 minutes)
JWT_EXPIRES_IN=30m